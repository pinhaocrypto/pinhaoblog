---
import Layout from '../layouts/Layout.astro';
import type { CollectionEntry } from 'astro:content';
import { topicToSlug } from '../lib/pensieve';

interface Props {
  entry?: CollectionEntry<'pages'>;
  items?: CollectionEntry<'pensieve'>[];
  baseSlug?: string;
  title?: string;
  description?: string;
  backHref?: string;
  backLabel?: string;
}

const {
  entry,
  items = [],
  baseSlug = 'pensieve',
  title: titleOverride,
  description: descriptionOverride,
  backHref,
  backLabel,
} = Astro.props;
const renderedEntry = entry ? await entry.render() : null;
const Content = renderedEntry?.Content;
const title = titleOverride ?? entry?.data.title ?? 'Pensieve';
const description = descriptionOverride ?? entry?.data.description;
const hasIntro = Boolean(Content && (entry?.body ?? '').trim().length > 0);
const kindLabels = {
  note: 'Note',
  essay: 'Essay',
  question: 'Question',
  memory: 'Memory',
};
const groupByYear = (posts: CollectionEntry<'pensieve'>[]) => {
  const grouped = new Map<string | number, CollectionEntry<'pensieve'>[]>();
  posts.forEach((post) => {
    const date = post.data.date ? new Date(post.data.date) : null;
    const year = date && !Number.isNaN(date.getFullYear()) ? date.getFullYear() : 'Undated';
    if (!grouped.has(year)) grouped.set(year, []);
    grouped.get(year)?.push(post);
  });

  return Array.from(grouped.entries())
    .sort((a, b) => (a[0] === 'Undated' ? 1 : b[0] === 'Undated' ? -1 : Number(b[0]) - Number(a[0])))
    .map(([year, posts]) => ({
      year,
      posts: posts.sort((a, b) => {
        const da = a.data.date ? new Date(a.data.date).getTime() : 0;
        const db = b.data.date ? new Date(b.data.date).getTime() : 0;
        return db - da;
      }),
    }));
};

const groupedPosts = groupByYear(items as CollectionEntry<'pensieve'>[]);
---

<Layout title={title} description={description}>
  <header class="blog-head page-marker">
    <h1>{title}</h1>
    {description && <p class="blog-desc">{description}</p>}
    {backHref && backLabel && <a class="blog-back" href={backHref}>← {backLabel}</a>}
  </header>

  {hasIntro && (
    <article class="blog-intro">
      <div class="post-content-body">
        {Content && <Content />}
      </div>
    </article>
  )}

  <section class="blog-index" aria-label="Pensieve entries">
    {groupedPosts.length === 0 ? (
      <p class="blog-empty">這裡還沒有想法。先留一點空白，等下一個念頭出現。</p>
    ) : groupedPosts.map(({ year, posts }) => (
      <div class="blog-year">
        <h2>{year}</h2>
        <ol>
          {posts.map((post) => (
            <li>
              <a class="entry-link" href={`/${baseSlug}/${post.slug}`}>
                <span>{post.data.title}</span>
                {post.data.date && (
                  <time datetime={post.data.date.toISOString()}>
                    {post.data.date.toLocaleDateString('zh-TW', {
                      year: 'numeric',
                      month: '2-digit',
                      day: '2-digit',
                    })}
                  </time>
                )}
              </a>
              <div class="thought-meta" aria-label="內容資訊">
                <span class="thought-kind">{kindLabels[post.data.kind]}</span>
                {post.data.updated && (
                  <span class="thought-updated">
                    Updated <time datetime={post.data.updated.toISOString()}>{post.data.updated.toLocaleDateString('zh-TW')}</time>
                  </span>
                )}
                {post.data.topics.map((topic) => (
                  <a class="thought-topic" href={`/pensieve/topic/${topicToSlug(topic)}`}>#{topic}</a>
                ))}
              </div>
              {post.data.description && <p>{post.data.description}</p>}
            </li>
          ))}
        </ol>
      </div>
    ))}
  </section>
</Layout>

<style>
  .blog-head {
    max-width: 720px;
    margin: 0 auto var(--space-lg);
    padding: 0;
    text-align: left;
  }

  .blog-desc {
    flex-basis: 100%;
    max-width: 60ch;
    margin: var(--space-sm) 0 0;
    font-family: var(--font-serif);
    font-size: var(--text-lead);
    line-height: 1.45;
    color: var(--color-text-subtle);
    text-wrap: pretty;
  }

  .blog-back {
    flex-basis: 100%;
    width: fit-content;
    margin-top: var(--space-md);
    font-family: var(--font-sans-serif);
    font-size: var(--text-label);
  }

  .blog-intro {
    max-width: 760px;
    margin: 0 auto var(--space-xl);
    padding: 0;
  }

  .blog-index {
    max-width: 760px;
    margin: var(--space-xl) auto;
    padding: 0;
  }

  .blog-year {
    display: grid;
    grid-template-columns: 6.4rem minmax(0, 1fr);
    gap: var(--space-lg);
    padding: var(--space-lg) 0;
    border-top: 1px solid var(--color-border);
  }

  .blog-year h2 {
    margin: 0;
    font-family: var(--font-sans-serif);
    font-size: var(--text-label);
    font-weight: 500;
    letter-spacing: 0.1em;
    font-variant-numeric: tabular-nums;
  }

  .blog-year ol {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .blog-year li + li {
    margin-top: var(--space-lg);
  }

  .entry-link {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-lg);
    min-height: 4.4rem;
    color: var(--color-base);
    text-decoration-thickness: 1px;
    text-underline-offset: 0.2em;
  }

  .entry-link > span {
    min-width: 0;
    overflow-wrap: anywhere;
    font-family: var(--font-serif);
    font-size: var(--text-entry);
    font-weight: 400;
    line-height: 1.25;
    text-wrap: pretty;
  }

  .blog-year time,
  .blog-year p {
    color: var(--color-text-subtle);
  }

  .thought-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm) var(--space-md);
    margin-top: var(--space-sm);
    color: var(--color-text-subtle);
    font-family: var(--font-sans-serif);
    font-size: var(--text-meta);
    line-height: 1.3;
    letter-spacing: 0.04em;
  }

  .thought-kind,
  .thought-updated {
    text-transform: uppercase;
  }

  .thought-topic {
    color: inherit;
    text-transform: none;
    text-underline-offset: 0.2em;
  }

  .blog-year time {
    flex: none;
    font-family: var(--font-sans-serif);
    font-size: var(--text-meta);
    font-variant-numeric: tabular-nums;
  }

  .blog-year p {
    max-width: 65ch;
    margin: var(--space-sm) 0 0;
    font-family: var(--font-serif);
    font-size: var(--text-body);
    line-height: 1.65;
    text-wrap: pretty;
  }

  .blog-empty {
    margin: 0;
    padding: var(--space-lg) 0 var(--space-xl);
    color: var(--color-text-subtle);
    font-size: var(--text-body);
  }

  @media (max-width: 720px) {
    .blog-year {
      grid-template-columns: 1fr;
      gap: var(--space-md);
    }

    .entry-link {
      align-items: flex-start;
      flex-direction: column;
      gap: var(--space-sm);
    }
  }
</style>
