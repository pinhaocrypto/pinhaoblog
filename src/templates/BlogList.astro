---
import Layout from '../layouts/Layout.astro';
import type { CollectionEntry } from 'astro:content';
import { topicToSlug } from '../lib/pensieve';

interface Props {
  entry?: CollectionEntry<'pages'>;
  items?: CollectionEntry<'pensieve'>[];
  baseSlug?: string;
  title?: string;
  description?: string;
  backHref?: string;
  backLabel?: string;
}

const {
  entry,
  items = [],
  baseSlug = 'pensieve',
  title: titleOverride,
  description: descriptionOverride,
  backHref,
  backLabel,
} = Astro.props;
const renderedEntry = entry ? await entry.render() : null;
const Content = renderedEntry?.Content;
const title = titleOverride ?? entry?.data.title ?? 'Pensieve';
const description = descriptionOverride ?? entry?.data.description;
const hasIntro = Boolean(Content && (entry?.body ?? '').trim().length > 0);
const kindLabels = {
  note: 'Note',
  essay: 'Essay',
  question: 'Question',
  memory: 'Memory',
};
const isMainPensieve = entry?.data.templateKey === 'pensieve-page' && !backHref;
const featuredPost = isMainPensieve ? items[0] : undefined;
const featuredRendered = featuredPost ? await featuredPost.render() : null;
const FeaturedContent = featuredRendered?.Content;
const indexItems = featuredPost ? items.slice(1) : items;
const formatDate = (date: Date) => date.toLocaleDateString('zh-TW', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
});
---

<Layout title={title} description={description}>
  <header class:list={['blog-head', { 'blog-head--main': isMainPensieve }]}>
    <h1 class:list={{ 'visually-hidden': isMainPensieve }}>{title}</h1>
    {description && <p class="blog-desc">{description}</p>}
    {backHref && backLabel && <a class="blog-back" href={backHref}>← {backLabel}</a>}
  </header>

  {hasIntro && (
    <article class="blog-intro">
      <div class="post-content-body">
        {Content && <Content />}
      </div>
    </article>
  )}

  {featuredPost && FeaturedContent && (
    <article class="featured-entry">
      <header>
        <h2>
          <a href={`/${baseSlug}/${featuredPost.slug}`}>{featuredPost.data.title}</a>
        </h2>
        {featuredPost.data.description && (
          <p class="featured-description">{featuredPost.data.description}</p>
        )}
      </header>

      {featuredPost.data.thumbnail && (
        <img
          class="featured-image"
          src={featuredPost.data.thumbnail}
          alt={featuredPost.data.title}
          loading="lazy"
          decoding="async"
        />
      )}

      <div class="featured-body">
        <FeaturedContent />
      </div>

      <footer class="featured-meta" aria-label="內容資訊">
        {featuredPost.data.date && (
          <time datetime={featuredPost.data.date.toISOString()}>
            {formatDate(featuredPost.data.date)}
          </time>
        )}
        <span>{kindLabels[featuredPost.data.kind]}</span>
        {featuredPost.data.updated && (
          <span>
            Updated <time datetime={featuredPost.data.updated.toISOString()}>{formatDate(featuredPost.data.updated)}</time>
          </span>
        )}
        {featuredPost.data.topics.map((topic) => (
          <a href={`/pensieve/topic/${topicToSlug(topic)}`}>#{topic}</a>
        ))}
      </footer>
    </article>
  )}

  <section class="blog-index" aria-label="Pensieve entries">
    {featuredPost && indexItems.length > 0 && <h2 class="index-title">Earlier</h2>}
    {!featuredPost && <h2 class="visually-hidden">Entries</h2>}

    {indexItems.length === 0 && !featuredPost ? (
      <p class="blog-empty">這裡還沒有想法。先留一點空白，等下一個念頭出現。</p>
    ) : indexItems.length > 0 && (
      <ol class="entry-list">
        {indexItems.map((post) => (
          <li>
            <div class="entry-heading">
              <a class="entry-link" href={`/${baseSlug}/${post.slug}`}>{post.data.title}</a>
              {post.data.date && (
                <time datetime={post.data.date.toISOString()}>
                  {formatDate(post.data.date)}
                </time>
              )}
            </div>
            {post.data.description && <p>{post.data.description}</p>}
            <div class="thought-meta" aria-label="內容資訊">
              <span>{kindLabels[post.data.kind]}</span>
              {post.data.updated && (
                <span>
                  Updated <time datetime={post.data.updated.toISOString()}>{formatDate(post.data.updated)}</time>
                </span>
              )}
              {post.data.topics.map((topic) => (
                <a href={`/pensieve/topic/${topicToSlug(topic)}`}>#{topic}</a>
              ))}
            </div>
          </li>
        ))}
      </ol>
    )}
  </section>
</Layout>

<style>
  .blog-head {
    max-width: 680px;
    margin: 0 auto 6rem;
    padding: 0;
    text-align: left;
  }

  .blog-head h1 {
    margin: 0 0 1rem;
    font-family: var(--font-reading);
    font-size: 2rem;
    font-weight: 650;
    line-height: 1.3;
  }

  .blog-head--main {
    margin-bottom: 7rem;
  }

  .blog-desc {
    max-width: 58ch;
    margin: 0;
    font-family: var(--font-reading);
    font-size: 1.55rem;
    line-height: 1.65;
    color: var(--color-text-subtle);
    text-wrap: pretty;
  }

  .blog-back {
    display: inline-block;
    margin-top: 1.6rem;
    color: var(--color-text-subtle);
    font-family: var(--font-reading);
    font-size: 1.3rem;
  }

  .blog-intro {
    max-width: 680px;
    margin: 0 auto 7rem;
    padding: 0;
  }

  .featured-entry {
    max-width: 680px;
    margin: 0 auto;
  }

  .featured-entry > header {
    margin-bottom: 4rem;
    text-align: center;
  }

  .featured-entry h2 {
    margin: 0;
    font-family: var(--font-reading);
    font-size: clamp(2rem, 3vw, 2.2rem);
    font-weight: 650;
    line-height: 1.3;
    text-wrap: balance;
  }

  .featured-entry h2 a {
    color: var(--color-base);
    text-decoration: none;
  }

  .featured-entry h2 a:hover {
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.2em;
  }

  .featured-description {
    max-width: 58ch;
    margin: 1rem auto 0;
    color: var(--color-text-subtle);
    font-size: 1.5rem;
    line-height: 1.6;
  }

  .featured-image {
    display: block;
    width: 100%;
    height: auto;
    margin: 0 0 4rem;
    border-radius: var(--radius);
  }

  .featured-body {
    font-family: var(--font-reading);
    font-size: 1.65rem;
    line-height: 1.72;
  }

  .featured-body :global(p),
  .featured-body :global(blockquote),
  .featured-body :global(ol),
  .featured-body :global(ul) {
    text-wrap: pretty;
  }

  .featured-body :global(a) {
    color: var(--color-base);
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, currentColor 25%, transparent);
    text-underline-offset: 0.2em;
  }

  .featured-body :global(a:hover) {
    text-decoration-color: currentColor;
  }

  .featured-body :global(h2) {
    margin: 5.6rem 0 1.6rem;
    font-size: 2rem;
    font-weight: 650;
    line-height: 1.35;
  }

  .featured-body :global(h3) {
    margin: 3.6rem 0 1.2rem;
    font-size: 1.75rem;
    font-weight: 650;
    line-height: 1.4;
  }

  .featured-body :global(li) {
    line-height: 1.72;
  }

  .featured-body :global(img) {
    display: block;
    max-width: 100%;
    height: auto;
    margin: 3rem auto;
  }

  .featured-body :global(hr) {
    margin: 5rem 0;
    border: 0;
    border-top: 1px solid var(--color-border);
  }

  .featured-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.2rem;
    margin-top: 4rem;
    color: var(--color-text-subtle);
    font-family: var(--font-reading);
    font-size: 1.15rem;
    line-height: 1.5;
    font-variant-numeric: tabular-nums;
  }

  .featured-meta a {
    color: inherit;
    text-underline-offset: 0.2em;
  }

  .blog-index {
    max-width: 680px;
    margin: 10rem auto 0;
    padding: 0;
  }

  .index-title {
    margin: 0 0 4rem;
    font-family: var(--font-reading);
    font-size: 1.5rem;
    font-weight: 650;
    line-height: 1.4;
  }

  .entry-list {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .entry-list li + li {
    margin-top: 5rem;
  }

  .entry-heading {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 2rem;
  }

  .entry-link {
    color: var(--color-base);
    font-family: var(--font-reading);
    font-size: 1.85rem;
    font-weight: 600;
    line-height: 1.35;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.2em;
    text-wrap: pretty;
  }

  .entry-heading > time {
    flex: none;
    color: var(--color-text-subtle);
    font-family: var(--font-reading);
    font-size: 1.15rem;
    font-variant-numeric: tabular-nums;
  }

  .entry-list p {
    max-width: 62ch;
    margin: 0.8rem 0 0;
    color: var(--color-text-subtle);
    font-size: 1.5rem;
    line-height: 1.6;
    text-wrap: pretty;
  }

  .thought-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.2rem;
    margin-top: 1rem;
    color: var(--color-text-subtle);
    font-family: var(--font-reading);
    font-size: 1.1rem;
    line-height: 1.45;
    font-variant-numeric: tabular-nums;
  }

  .thought-meta a {
    color: inherit;
    text-underline-offset: 0.2em;
  }

  .blog-empty {
    margin: 0;
    color: var(--color-text-subtle);
    font-size: 1.5rem;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 520px) {
    .blog-head--main {
      margin-bottom: 6rem;
    }

    .featured-entry > header {
      margin-bottom: 3.6rem;
    }

    .featured-body {
      font-size: 1.6rem;
    }

    .blog-index {
      margin-top: 8rem;
    }

    .entry-heading {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.5rem;
    }
  }
</style>
