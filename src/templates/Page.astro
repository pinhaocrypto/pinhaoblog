---
import Layout from '../layouts/Layout.astro';
import { type CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'pages'>;
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const { title, description, thumbnail } = entry.data;
const pageNumbers: Record<string, string> = {
  bio: '01',
  work: '02',
};
const pageNumber = pageNumbers[entry.slug];

// Image handling: thumbnail is string path to /public/img/...
// In Astro, if it is in public, just use the path.
// If imported, use Image component. Legacy used string paths in frontmatter.
---

<Layout title={title} description={description}>
  <article class={`post-content ${thumbnail ? '' : 'no-image'}`}>
    <header class="page-marker">
      {pageNumber && <span aria-hidden="true">{pageNumber}</span>}
      <h1>{title}</h1>
    </header>

    {thumbnail && (
      <div class="post-content-image">
        <img src={thumbnail} class="kg-image" alt={title} />
      </div>
    )}

    <div class="post-content-body">
      <Content />
    </div>

    <footer class="post-content-footer">
    </footer>
  </article>
</Layout>
