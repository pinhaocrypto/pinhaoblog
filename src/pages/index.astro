---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allPages = await getCollection('pages');
const recentPosts = (await getCollection('pensieve'))
	.filter((post) => !import.meta.env.PROD || !post.data.draft)
	.sort((a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0))
	.slice(0, 3);
const indexPage = allPages.find((p) => p.slug === 'index');
const { Content } = indexPage ? await indexPage.render() : { Content: null };

const browserTitle = 'MNIPH';
const description = indexPage?.data.description;
const heading = indexPage?.data.heading || '';
const subheading = indexPage?.data.subheading || '';
const heroImageLight = indexPage?.data.heroImageLight ?? indexPage?.data.image;
const heroImageDark = indexPage?.data.heroImageDark ?? null;
const heroImageAlt = indexPage?.data.heroImageAlt || 'Seoul Hangang skyline';
const hasHeroImage = heroImageLight || heroImageDark;
---

<Layout title={browserTitle} description={description} image={heroImageLight}>
	<section class="home-garden">
		<header class="home-garden__intro">
			{heading && <h1>{heading}</h1>}
			{subheading && <p>{subheading}</p>}
		</header>
	{hasHeroImage && (
		<figure class="home-garden__image">
			{heroImageLight && (
				<img
					src={heroImageLight}
					alt={heroImageAlt}
					class="home-garden__img home-garden__img--light"
					loading="eager"
					decoding="async"
				/>
			)}
			{heroImageDark && (
				<img
					src={heroImageDark}
					alt={heroImageAlt}
					class="home-garden__img home-garden__img--dark"
					loading="lazy"
					decoding="async"
				/>
			)}
		</figure>
	)}
	<section class="home-garden__section" aria-labelledby="recent-writing">
		<h2 id="recent-writing">Recently written</h2>
		<ol class="recent-writing">
			{recentPosts.map((post) => (
				<li>
					<a href={`/pensieve/${post.slug}`}>{post.data.title}</a>
					{post.data.date && (
						<time datetime={post.data.date.toISOString()}>
							{post.data.date.toLocaleDateString('zh-TW', {
								year: 'numeric',
								month: '2-digit',
								day: '2-digit',
							})}
						</time>
					)}
					{post.data.description && <p>{post.data.description}</p>}
				</li>
			))}
		</ol>
	</section>
	{Content && (
		<article class="home-garden__body">
			<Content />
		</article>
		)}
	</section>
</Layout>

<style>
	.home-garden {
		max-width: 760px;
		margin: 0 auto;
		padding: 2rem 1.5rem 6rem;
	}

	.home-garden__intro {
		max-width: 54rem;
		margin-bottom: 3rem;
	}

	.home-garden__intro h1 {
		margin: 0;
		font-family: var(--font-serif);
		font-size: clamp(2.2rem, 4vw, 3rem);
		font-weight: 400;
		line-height: 1.2;
	}

	.home-garden__intro p {
		margin: 0.8rem 0 0;
		color: var(--color-text-subtle);
		font-size: 1.75rem;
		line-height: 1.6;
	}

	.home-garden__image {
		margin: 0 0 4rem;
	}

	.home-garden__img {
		display: block;
		width: 100%;
		border-radius: var(--radius);
		border: 1px solid var(--color-border);
	}

	.home-garden__section {
		padding: 2.5rem 0;
		border-top: 1px solid var(--color-border);
	}

	.home-garden__section h2 {
		margin: 0 0 1.8rem;
		font-family: var(--font-sans-serif);
		font-size: 1.35rem;
		font-weight: 500;
		letter-spacing: 0.1em;
		text-transform: uppercase;
	}

	.home-garden__body :global(h2) {
		margin: 2.5rem 0 1.8rem;
		padding-top: 2.5rem;
		border-top: 1px solid var(--color-border);
		font-family: var(--font-sans-serif);
		font-size: 1.35rem;
		font-weight: 500;
		letter-spacing: 0.1em;
		text-transform: uppercase;
	}

	.recent-writing {
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.recent-writing li + li {
		margin-top: 2rem;
	}

	.recent-writing a {
		color: var(--color-base);
		font-size: 2.2rem;
		line-height: 1.25;
		text-decoration-thickness: 1px;
		text-underline-offset: 0.25em;
	}

	.recent-writing time {
		display: block;
		margin-top: 0.4rem;
		color: var(--color-text-subtle);
		font-family: var(--font-sans-serif);
		font-size: 1.2rem;
	}

	.recent-writing p {
		margin: 0.5rem 0 0;
		color: var(--color-text-subtle);
		font-size: 1.6rem;
		line-height: 1.5;
	}

	.home-garden__body :global(h3) {
		margin: 1.8rem 0 0.5rem;
		font-family: var(--font-sans-serif);
		font-size: 1.45rem;
		font-weight: 500;
	}

	.home-garden__body :global(p),
	.home-garden__body :global(li) {
		font-size: 1.7rem;
		line-height: 1.65;
	}

	.home-garden__body :global(ul) {
		margin: 0;
		padding-left: 1.2em;
	}

	@media (max-width: 520px) {
		.home-garden {
			padding-right: 0;
			padding-left: 0;
	}
	}

	.home-garden__img + .home-garden__img {
		margin-top: 1rem;
	}
	</style>

<style is:global>
	html:not([data-theme='dark']) .home-garden__img--light {
		display: block;
	}

	html:not([data-theme='dark']) .home-garden__img--dark {
		display: none;
	}

	html[data-theme='dark'] .home-garden__img--light {
		display: none;
	}

	html[data-theme='dark'] .home-garden__img--dark {
		display: block;
	}
</style>
