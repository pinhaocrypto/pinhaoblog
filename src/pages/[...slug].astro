---
import { getCollection } from 'astro:content';
import Page from '../templates/Page.astro';
import BlogList from '../templates/BlogList.astro';

export async function getStaticPaths() {
  const pages = await getCollection('pages');

  const blogEntries = (await getCollection('pensieve')).filter(
    (entry) => !import.meta.env.PROD || !entry.data.draft,
  );

  // Sort them
  const sortDate = (a, b) => new Date(b.data.date || 0).getTime() - new Date(a.data.date || 0).getTime();
  const sortedBlog = blogEntries.sort(sortDate);

  return pages.filter((entry) => entry.slug !== 'index').map(entry => {
    // Determine props based on templateKey
    let props = { entry };
    let items = [];
    let baseSlug = '';

    if (entry.data.templateKey === 'pensieve-page') {
        items = sortedBlog;
        baseSlug = 'pensieve';
    }

    return {
      params: { slug: entry.slug },
      props: { ...props, items, baseSlug },
    };
  });
}

const { entry, items, baseSlug } = Astro.props;
const templateKey = entry.data.templateKey;
---

{templateKey === 'pensieve-page' ? (
    <BlogList entry={entry} items={items} baseSlug={baseSlug} />
) : (
    <Page entry={entry} />
)}
