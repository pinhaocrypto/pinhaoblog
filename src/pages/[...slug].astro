---
import { getCollection } from 'astro:content';
import Page from '../templates/Page.astro';
import BlogList from '../templates/BlogList.astro';
import { sortPensieveEntries, visiblePensieveEntries } from '../lib/pensieve';

export async function getStaticPaths() {
  const pages = await getCollection('pages');

  const sortedBlog = sortPensieveEntries(
    visiblePensieveEntries(await getCollection('pensieve')),
  );

  return pages.filter((entry) => entry.slug !== 'index').map(entry => {
    // Determine props based on templateKey
    let props = { entry };
    let items = [];
    let baseSlug = '';

    if (entry.data.templateKey === 'pensieve-page') {
        items = sortedBlog;
        baseSlug = 'pensieve';
    }

    return {
      params: { slug: entry.slug },
      props: { ...props, items, baseSlug },
    };
  });
}

const { entry, items, baseSlug } = Astro.props;
const templateKey = entry.data.templateKey;
---

{templateKey === 'pensieve-page' ? (
    <BlogList entry={entry} items={items} baseSlug={baseSlug} />
) : (
    <Page entry={entry} />
)}
